# Path to the model file inside ./models/
SD_MODEL=model.gguf

# sd-server URL (set automatically by docker-compose, override for local dev)
SD_SERVER_URL=http://localhost:1234

# API server bind address and port
API_HOST=0.0.0.0
API_PORT=8765

# Directory where /generate/file saves output PNGs
OUTPUT_DIR=./outputs
